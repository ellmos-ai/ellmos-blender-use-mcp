{
  "name": "ellmos-blender-use-mcp",
  "version": "0.1.0-alpha.3",
  "mcpName": "io.github.ellmos-ai/ellmos-blender-use-mcp",
  "description": "Local-first, add-on-free MCP asset-QA tool for headless Blender FBX reimport verification and background script runs",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "ellmos-blender-use": "src/index.js"
  },
  "files": [
    "src/",
    "LICENSE",
    "README.md",
    "README_de.md",
    "THIRD_PARTY_LICENSES.md",
    "server.json",
    "llms.txt",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node --check src/index.js",
    "test": "node test/privacy-hygiene.test.js && node test/runtime-safety.test.js",
    "start": "node src/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "blender",
    "bpy",
    "fbx",
    "glb",
    "asset-pipeline",
